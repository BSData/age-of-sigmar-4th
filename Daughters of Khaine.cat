              <characteristics>
                <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">For the rest of the phase, friendly **^^Daughters of Khaine Aelf Infantry^^** units have **^^Ward (5+)^^** until they have used a **^^Fight^^** ability</characteristic>
