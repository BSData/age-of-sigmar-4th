              <profiles>
                <profile name="Darkling Exilir" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="5465-2004-d248-90f1">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">End of Your Turn</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible friendly **^^Daughters of Khaine^^** unit wholly within 12&quot; of this unit to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice. On a 3+, the target can immediately use the &apos;Retreat&apos; ability as if it were your movement phase.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
