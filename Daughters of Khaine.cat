    <selectionEntryGroup name="Heroic Traits" id="9734-20e7-d9c1-322e" hidden="false">
      <selectionEntryGroups>
        <selectionEntryGroup name="Paragons of Murder" id="587d-33a3-60ea-7bfc" hidden="false">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Shadow-Blooded" hidden="false" id="9292-ae01-ee15-1433">
              <profiles>
                <profile name="Shadow-Blooded" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="5aa7-571c-650e-163f">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: You declared the &apos;Redeploy&apos; command for a **^^Daughters of Khaine^^** unit wholly within 12&quot; of this unit</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If you roll a 1-3 when determining the distance that unit can move, you can use a value of 4 instead.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Grey</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="c1c7-e096-f136-2d69" includeChildSelections="true"/>
              </constraints>
              <categoryLinks>
                <categoryLink targetId="75d6-6995-dfcc-3898" id="9d65-0b01-c1c7-9ebb" primary="false" name="INFANTRY"/>
              </categoryLinks>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Hand of Khaine" hidden="false" id="1c53-51cd-2912-1486">
              <profiles>
                <profile name="Hand of Khaine" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="dba4-17a7-3f99-7253">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Combat Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick an enemy **^^Hero^^** in combat with this unit to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll 2D6. If the roll exceeds the target&apos;s Health characteristic, it is automatically destroyed. If the target is destroyed by this ability, this unit can use 2 **^^Fight^^** abilities this phase. After the first is used, however, this unit has **^^Strike-Last^^** for the rest of the turn.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="5582-4b4a-8910-6c35" includeChildSelections="true"/>
              </constraints>
              <categoryLinks>
                <categoryLink targetId="75d6-6995-dfcc-3898" id="2323-b534-2a82-8a47" primary="false" name="INFANTRY"/>
              </categoryLinks>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Murderous Duellist" hidden="false" id="a6fc-8042-9ee1-78b2">
              <profiles>
                <profile name="Murderous Duellist" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="b195-c019-848e-623c">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Combat Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick an enemy unit that has no more than 1 model and is in combat with this unit to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll 2D6. If the roll equals or exceeds the target&apos;s Control characteristic, for the rest of the turn, if this unit is in combat with the target when the target is picked to use a **^^Fight^^** ability, all of the target&apos;s attacks must target this unit.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="13e2-24a7-a965-a6a5" includeChildSelections="true"/>
              </constraints>
              <categoryLinks>
                <categoryLink targetId="75d6-6995-dfcc-3898" id="a935-4ad4-2648-9b5f" primary="false" name="INFANTRY"/>
              </categoryLinks>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="49f4-1d7f-a67a-1a9d" hidden="true">
              <description>**^^Hero^^** only</description>
