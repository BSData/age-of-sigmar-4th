        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Frenzied Devotees" hidden="false" id="a0a1-f2ba-a292-99bb">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a130-68be-7fe4-01d2"/>
          </constraints>
          <profiles>
            <profile name="Heretic&apos;s Bane" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="c41e-7f4c-74b8-0227">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Start of Enemy Turn</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick an enemy **^^Wizard^^** or **^^Priest^^** on the battlefield to be the target.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice for each objective you control. For each 3+, subtract 1 from castitng rolls and chanting rolls for the target for the rest of the turn.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Black</attribute>
                <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
                <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Cold-Hearted Murderers" hidden="false" id="3bd1-a8a9-a734-68bb">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="1948-2811-0de7-b388"/>
          </constraints>
          <profiles>
            <profile name="Bloody-Handed Worshippers" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="4b6f-c471-9ca3-9813">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: You declared a Fight ability for an anointed unit</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Pick a friendly non-**^^Hero Daughters of Khaine^^** unit that has not used a **^^Fight^^** ability this turn and is within that **anointed** unit&apos;s combat range to the the target. The target  can be picked to use a **^^Fight^^** ability immediately after the **^^Fight^^** ability used by that **anointed** unit has been resolved. If it is picked to do so, the target&apos;s melee weapons have **Crit (Auto-wound)** for the rest of the turn. If the melee weapons already have **Crit (Auto-wound)**, they have **Crit (Mortal)** for the rest of the turn instead.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b">That **anointed** unit.</characteristic>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Fervent Ritualists" hidden="false" id="85d1-5b5c-67a3-f30a">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9a1e-4c2e-f1b4-c147"/>
          </constraints>
          <profiles>
            <profile name="Final Frenzy" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="7791-117b-28d4-bc4a">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), End of Any Turn</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick each friendly **^^Daughters of Khaine^^** unit contesting an objective to be the targets.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Return up to D3 slain models to each target that has a Health characteristic of up to 2.
Return up to 1 slain model to each target that that has a Health characteristic of 3 or more.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b">That **^^anointed^^** unit.</characteristic>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Purple</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Rallying</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
