        <selectionEntry type="upgrade" import="true" name="Coven of Blood" hidden="false" id="8b93-cab5-fc0f-61a4">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="bf9d-9126-da69-6301"/>
          </constraints>
          <profiles>
            <profile name="The Breath of Khaine" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="0dbf-063e-65b5-3879">
              <characteristics>
                <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While each model in a friendly **^^Daughters of Khaine^^** unit is contesting an objective you control, those models are not visible to enemy models more than 9&quot; away.</characteristic>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Black</attribute>
                <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
                <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
              </attributes>
