                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">If this unit is destroyed, before removing it from play, roll a dice for each visible unit (friendly and enemy) within its combat range. On a 3+, inflict an amount of mortal damage on that unit equal to the roll.</characteristic>
