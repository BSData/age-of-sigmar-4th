                <profile name="Commodore de Graçon" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="a919-15a5-fdd1-a0ef">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Deployment Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">This unit and up to 1 other friendly **^^Iron March War Machine^^** within this unit&apos;s combat range can use the &apos;Normal Move&apos; ability as if it were your movement phase.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
