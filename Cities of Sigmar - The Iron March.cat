                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Add 1 to wound rolls for combat attacks made by friendly **^^Iron March Infantry^^** while they are wholly within 12&quot; of this unit and **under orders**.</characteristic>
