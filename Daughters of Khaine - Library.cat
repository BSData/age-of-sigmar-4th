            <selectionEntry type="upgrade" import="true" name="Envenomed Tail" hidden="false" id="5fc8-8c90-efe3-71a9" sortIndex="2">
              <constraints>
                <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="881c-464f-e89a-fc54"/>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4967-daf5-5e17-be4b"/>
              </constraints>
              <profiles>
                <profile name="Envenomed Tail" typeId="9074-76b6-9e2f-81e3" typeName="Melee Weapon" hidden="false" id="3bf3-33a0-55-5862">
                  <characteristics>
