        <profile name="Aura of Agony" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="93af-9bbf-edc6-456e">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Hero Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of your next turn:
• Enemy **^^Manifestations^^** cannot be set up within 12&quot; of this unit.
• This unit has **^^Ward (4+)^^** against mortal damage inflicted by **^^Spell^^** abilities, **^^Prayer^^** abilities and abilities used by **^^Manifestations^^**.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
