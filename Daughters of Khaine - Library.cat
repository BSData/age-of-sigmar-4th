        <profile name="Heartseekers" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="f16d-95a0-bfc6-b0e7">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Reaction: You declared a SHOOT ability for this unit</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">After that **^^Shoot^^** ability has been resolved, if all of this unit&apos;s attacks targeted the same enemy unit, roll a dice. Add 1 to the roll if any other friendly **Blood Stalkers** units picked that enemy unit to be the target of all of their shooting attacks this turn. On a 3+, until the start of your next turn, subtract 1 from the number of dice rolled when making charge rolls for the target, to a minimum of 1.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
