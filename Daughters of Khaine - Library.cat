              <selectionEntries>
                <selectionEntry type="upgrade" import="true" name="Bellowed Exhortations" hidden="false" id="82f0-51d6-4296-e1fd">
                  <profiles>
                    <profile name="Bellowed Exhortations" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="d0dc-902e-b6e0-16f7">
                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Any Hero Phase</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible friendly non-**^^Hero Daughters of Khaine^^** unit wholly within 12&quot; of this unit to be the target.</characteristic>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If you have used the &apos;Blessings of Khaine&apos; ability 3 or more times this battle, the target&apos;s combat attacks score critical hits on unmodified hit rolls of 4+ for the rest of the turn. Otherwise, roll a dice. If the roll is equal to or less than the current battle round number, the target&apos;s combat attacks score critical hits on unmodified hit rolls of 4+ for the rest of the turn.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                      </characteristics>
                      <attributes>
                        <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                        <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                        <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                      </attributes>
                    </profile>
                  </profiles>
                  <constraints>
                    <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="c3f8-6cbd-8abd-5b85"/>
                  </constraints>
                </selectionEntry>
                <selectionEntry type="upgrade" import="true" name="Blessed of the Goddess" hidden="false" id="c6c0-5899-8deb-c8b2">
                  <profiles>
                    <profile name="Blessed of the Goddess" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="4927-f56c-80bd-5e84">
                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Your Hero Phase</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly **^^Daughters of Khaine Manifestation^^** that is not on the battlefield.</characteristic>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice. On a 4+, if you picked a **Heart of Fury**, set it up wholly within 18&quot; of this unit and visible to it. Otherwise, on a 4+, set up the **^^Manifestation^^** wholly within 12&quot; of this unit, visible to it and more than 9&quot; from all enemy units. This unit has summoned that **^^Manifestation^^**.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                      </characteristics>
                      <attributes>
                        <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                        <attribute name="Type" typeId="6d16-c86b-2698-85a4">Special</attribute>
                        <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
