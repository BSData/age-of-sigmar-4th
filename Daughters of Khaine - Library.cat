          </attributes>
        </profile>
        <profile name="Icon of Slaughter" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="1bc5-76b1-223d-8394">
          <characteristics>
            <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e">**^^Exalted^^**</characteristic>
            <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Each time a friendy **^^Daughters of Khaine^^** unit wholly within 12&quot; of this unit uses the `Rally` command, you can make 3 additional rally rolls of D6. In addition, if there are any friendly **Hag Queens on Cauldrons of Blood** on the battlefield when that command is used, you receive D3 additional rally points.</characteristic>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
            <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Rallying</attribute>
            <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
          </attributes>
        </profile>
      </profiles>
