        <selectionEntryGroup name="Artefacts of Power: Legions of Nagash" id="a3bb-fbb9-439b-ac53" hidden="false" publicationId="d979-992f-19fa-7e9d">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Soul-shrive Amulet" hidden="false" id="aa36-0182-df92-c78a">
              <profiles>
                <profile name="Soul-shrive Amulet" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="46ea-09f6-1b99-eca8">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Any Hero Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick **empowered agent** or **sacrificial pawn**.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If you picked **empowered agent**, for the rest of the turn:
• Add 2 to the Attacks characteristic of this unit&apos;s melee weapons.
• Add 1 to the Rend characteristic of this unit&apos;s melee weapons.
If you picked **sacrificial pawn**, instead of making a casting roll for the next spell cast by the friendly **Nagash** this turn, you can use a value of 7 for the roll that cannot be modified and that spell cannot be unbound. Then, allocate 3 damage points to this unit (ward rolls cannot be made for those damage points).</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Special</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="5ba1-80ff-15aa-8775" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="257e-7b66-b06d-0712" hidden="true">
              <description>**^^Hero^^** only</description>
            </rule>
          </rules>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <entryLinks>
