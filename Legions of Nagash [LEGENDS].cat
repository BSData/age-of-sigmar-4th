          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Inescapable Fate" hidden="false" id="dce6-2b29-6653-fffa">
              <profiles>
                <profile name="Inescapable Fate" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="8f5a-f43b-f9fd-147c">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, End of Any Turn</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">This unit can only use this ability if it has been destroyed.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If the friendly **Nagash** is on the battlefield, set up a replacement of this unit wholly within 12&quot; of that **Nagash** and more than 9&quot; from all enemy units. If this unit is not **^^Infantry^^** or **^^Cavalry^^**, allocate 8 damage points to it (ward rolls cannot be made for those damage points).</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Purple</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Rallying</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="0e66-ef16-0822-5317" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
