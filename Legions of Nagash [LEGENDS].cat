          </attributes>
        </profile>
        <profile name="Soul Devourer" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="2371-82d7-c087-471f">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">End of Any Turn</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick any number of units (friendly or enemy) within this unit&apos;s combat range to be the targets.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Inflict D6 mortal damage on each target. For each model slain by this ability, **Heal (1)** this unit.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f">**^^Rampage^^**</characteristic>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Purple</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Rallying</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Father of Necromancy" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="2b48-9fc8-6510-bba2">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Your Hero Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick 2 visible friendly **^^Legions of Nagash^^** units that are wholly within 18&quot; of this unit. Pick 1 of those units to be the target, then pick the other to be **drained**.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Up to 3 models in the **drained** unit are automatically slain. Then, return a number of slain models to the target unit with a combined Health characteristic of models slain in the **drained** unit.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute typeId="5a11-eab3-180c-ddf5" name="Color">Yellow</attribute>
            <attribute typeId="6d16-c86b-2698-85a4" name="Type">Rallying</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Necromantic Empowerment" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="85ea-25f2-cf1e-855c">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Onec Per Turn (Army), Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a viisble friendly **Legions of Nagash** unit within this unit&apos;s combat range to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Allocate D3 mortal damage to the target (ward rolls cannot be made for those damage points). If any models are slain by this ability, for the rest of the turn:
• This unit&apos;s **Alakanash** has **Crit (Mortal)**.
• This unit&apos;s **Zefet-nebtar** has **Crit (2 Hits)**.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f">**^^Rampage^^**</characteristic>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4"/>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa">Offensive</attribute>
          </attributes>
        </profile>
