                <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Add 1 to the Rend characteristic of melee weapons used by friendly **^^Sybarite Infantry^^** units while they are wholly outside friendly territory</characteristic>
              </characteristics>
