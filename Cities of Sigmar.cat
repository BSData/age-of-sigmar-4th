    <selectionEntryGroup name="Decorations for Valour" id="48fa-1e1e-5798-4d54" hidden="false">
      <selectionEntryGroups>
        <selectionEntryGroup name="Decorations for Valour" id="7ad1-832e-3c34-765b" hidden="true" publicationId="9e18-bb03-7b60-d4ff">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Twin-tailed Comet of Honour" hidden="false" id="40ea-6840-899c-f688">
              <profiles>
                <profile name="Twin-tailed Comet of Honour" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="a8dc-1c3e-5c04-e9bf">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While this unit has any champions, add 5 to this unit's control score.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Purple</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Control</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="743a-10b5-1f65-ad69" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="The Living City Cross" hidden="false" id="b4fc-7ddb-de71-de0e">
              <profiles>
                <profile name="The Living City Cross" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="15a0-434e-936f-4a6c">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While this unit has any champions, subtract 1 from hit rolls for shooting attacks that target this unit.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Green</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="dd71-f5c3-fd6a-88ad" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Aqshian Order of Merit" hidden="false" id="5c50-a317-fabd-9493">
              <profiles>
                <profile name="Aqshian Order of Merit" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="153b-7b1e-a4e2-1d46">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While this unit has any champions, if an enemy unit in combat with this unit uses the 'Eruption of Fury' ability, when resolving attacks as part of that ability, on an unmodified hit roll of 6, do not inflict an additional D3 mortal damage on each unit in combat with that unit.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Purple</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="f5c5-6b2d-1ade-3690" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="6c0c-608b-d13c-662a" hidden="true">
              <description>Decorations for Valour are unique enhancements that can be given to **^^Cities of Sigmar^^** units that have the **^^Champion^^** keyword. A unit can only have 1 Decoration for Valour.</description>
            </rule>
          </rules>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
