            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="e9f3-98fb-3158-195b" hidden="true">
              <description>**Cannonade Cogfort** and **Conqueror Cogfort** only</description>
