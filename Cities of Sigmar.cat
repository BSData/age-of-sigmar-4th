        <selectionEntryGroup name="Sentinels of Order" id="720d-9f2a-4ed6-112e" hidden="true" publicationId="9e18-bb03-7b60-d4ff">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Pious Veteran" hidden="false" id="d8e9-0953-861a-f5ce">
              <profiles>
                <profile name="Pious Veteran" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="8e0d-979a-de56-2489">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Each time you pick targets while declaring a **^^Prayer^^** ability used by a friendly **^^Cities of Sigmar Priest^^**, if this unit is eligible to be picked, you can pick it to be an additional target</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Special</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="2ddf-8e75-b9d9-9211" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Bristling Attitude" hidden="false" id="cdca-aa12-22a4-b08b">
              <profiles>
                <profile name="Bristling Attitude" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="c6d2-baa2-0a6e-bbf3">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: Opponent declared a **^^Charge^^** ability for a visible unit within 12&quot; of this unit</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Spend any number of rage dice. If your opponent's **fury level** is lower than yours, they must increase their **fury level** by 1, to a maximum of 7. Then, roll **X** dice, where **X** is the number of rage dice spent. For each 3+, subtract 1 from the charge roll. </characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Orange</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="04ca-1143-e951-2710" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Cosmopolitan Leader" hidden="false" id="8bdf-4039-228c-c732">
              <profiles>
                <profile name="Cosmopolitan Leader" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="f5f0-74f8-04db-e9f0">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Your Hero Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick up to 3 visible friendly non‑**^^War Machine Sigmarite^^** units wholly within 12&quot; of this unit to be the targets.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Spend 1 **rage dice** for each target. If your opponent's **fury level** is lower than yours, they must increase their **fury level** by 1, to a maximum of 7. Then, add 1 to wound rolls for each target's combat attacks until the start of your next turn.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute typeId="50fe-4f29-6bc3-dcc6" name="Color">Yellow</attribute>
                    <attribute typeId="bf11-4e10-3ab1-06f4" name="Type">Offensive</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
