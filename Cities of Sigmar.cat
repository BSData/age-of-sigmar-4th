  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Battle Traits: Cities of Sigmar" hidden="false" id="7cf4-ebee-6d30-c1e1">
      <profiles>
        <profile name="Form Up" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="ba11-eaf6-71e9-213">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Start of Battle Round</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly **^^Cities of Sigmar ^^** unit to use this ability, then pick 2 other visible friendly **^^Cities of Sigmar^^** units wholly within 12&quot; of it to be the targets.
The unit using this ability and the targets:
• cannot be **under orders**.
• must each be a different unit type.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the battle round, the unit using this ability and the targets are **under orders**.
**Designer&apos;s Note:** *&apos;Unit type&apos; refers to the name of the warscroll (Core Rules, 4.0), e.g. &apos;Freeguild Cavalier-Marshal&apos; or &apos;Cannonade Cogfort&apos;.*</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f">**^^Officar&apos;s Order^^**</characteristic>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Black</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Special</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Take Aim" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="11c5-c994-64df-350a">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Shooting Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly unit that is **under orders** to use this ability.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Pick 1 of that unit&apos;s ranged weapons. Add 1 to hit rolls for shooting attacks made with that weapon for the rest of the turn.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Shooting</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Sound the Attack" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="7b07-d086-b6a7-c4a0">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Reaction: You declared a **^^Charge^^** ability for a unit that is **under orders**</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">You can change the lowest D6 in the charge roll to match the highest D6.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b">The unit using that **^^Charge^^** ability.</characteristic>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Orange</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Into Them, You Dogs!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="c8e5-fb20-1bc4-bb45">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly **^^Hero^^** that is **under orders** to use this ability. That unit is the **field officer** for the rest of the turn. Then, pick 2 other visible friendly non-**^^Hero^^** units that are **under orders** and wholly within 12&quot; of the **field officer** to be the targets.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the turn, the first time the **field officer** uses a **^^Fight^^** ability, you can pick a target that has not used a **^^Fight^^** ability this turn. That target is **inspirited** and the other target is **emboldened**.The **inspirited** target can be picked to use a **^^Fight^^** ability immediately after the **^^Fight^^** ability used by the **field officer** has been resolved. Then, if the **emboldened** target has not used a **^^Fight^^** ability this turn, it can be picked to use a **^^Fight^^** ability immediately after the **inspirited** target&apos;s **^^Fight^^** ability has been resolved.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Hurl Them Back!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="61f3-1539-8aa3-9e05">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">One Per Turn (Army), Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly unit that is **under orders** and in combat with an enemy unit that charged this turn to use this ability.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the turn, add 1 to the Rend characteristic of that unit&apos;s melee weapons.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Reference" hidden="false" id="f995-9030-2bf3-91ac" targetId="3360-1158-e879-9606" primary="true"/>
      </categoryLinks>
    </selectionEntry>
  </sharedSelectionEntries>
