              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="9d6-a51f-cd81-76e7" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Grizzled Drillmaster" hidden="false" id="b922-2043-5ced-e0b1">
              <profiles>
                <profile name="Grizzled Drillmaster" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="64bf-6ab8-2a48-192">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Other visible friendly units have **^^Ward (6+)^^** while they are wholly within 12&quot; of this unit and **under orders**.</characteristic>
                  </characteristics>
