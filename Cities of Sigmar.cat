              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="330e-b779-2d57-19df" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="df21-515d-1b70-39ae" hidden="true">
              <description>**^^Hero^^** only, excluding **Cannonade Cogfort** and **Conqueror Cogfort**</description>
            </rule>
          </rules>
