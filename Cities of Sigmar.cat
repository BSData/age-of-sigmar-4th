    <selectionEntryGroup name="Battle Formations: Cities of Sigmar" id="bb8f-ca64-b083-4c7b" hidden="false" flatten="true">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Stalwart Guardians" hidden="false" id="a769-683a-19c8-5f98" publicationId="a746-732d-1a22-460">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e165-684-2253-9673"/>
          </constraints>
          <profiles>
            <profile name="To the Last" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="b49a-35fc-1cf5-7848">
              <characteristics>
                <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Each time a friendly unit that is **under orders** uses the &apos;Rally&apos; command, you can make 3 additional rally rolls of D6.</characteristic>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
                <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Rallying</attribute>
                <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Collegiate Exemplars" hidden="false" id="225e-a217-d55-2cb0" publicationId="a746-732d-1a22-460">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="454b-b9bd-5593-11f0"/>
          </constraints>
          <profiles>
            <profile name="Masters of the Arcane" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="df89-8c5c-57fa-fd29">
              <characteristics>
                <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Add 1 to arcane manipulation rolls and banishment rolls for friendly **^^Wizards^^** that are **under orders**.
**Designer&apos;s Note:** *Wizards in this battletome use arcane manipulation rolls for a variety of powerful effects.*</characteristic>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
                <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Special</attribute>
                <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Zealous Hordes" hidden="false" id="9cd5-6e01-a51e-4b41">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="4ab6-3bb3-274f-210e"/>
          </constraints>
          <profiles>
            <profile name="Throngs of the Faithful" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="f184-caa1-5d57-f9be">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Reaction: Your opponent declared a **^^Fight^^** ability.</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the turn, add 1 to wound rolls for combat attacks made by friendly **^^Sigmarite^^** units that target the enemy unit using that **^^Fight^^** ability.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Swift Reinforcements" hidden="false" id="7022-54db-fb73-5d95" publicationId="a746-732d-1a22-460">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9bcd-9628-36a2-a090"/>
          </constraints>
          <profiles>
            <profile name="Dawnbringer Crusade" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="f462-cd42-adfd-a4ac">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Hero Phase</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly non-**^^Hero Cities of Sigmar Infantry^^** unit wholly within friendly territory to use this ability.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If that unit is in combat, it can move 6&quot;. It can move through the combat ranges of enemy units but can only end that move in combat with units it was in combat with at the start of the move. It does not have to end the move in combat.
If that unit is not in combat, it can move 6&quot;. It cannot move into combat during any part of that move.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f">**^^Move^^**</characteristic>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Veteran Cannoneers" hidden="true" id="a574-28e2-35a2-5378" publicationId="f894-7929-f79a-a269">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9780-c139-0ee6-1bfd"/>
          </constraints>
          <profiles>
            <profile name="Canny Crews" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="dc6e-50ac-e432-4f94">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Shooting Phase</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick up to 3 friendly **Ironweld Great Cannon** units to be the targets.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the turn, each time the target uses a **^^Shoot^^** ability, you can re-roll 1 hit roll, or 1 wound roll, or 1 random characteristic roll for the Damage characteristic</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Shooting</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="78a1-f6c2-71b8-270a" shared="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="f079-501a-2738-6845" shared="true"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
            <modifier type="set" value="0" field="points">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="1bed-ddb5-0c50-16d2" shared="true" includeChildSelections="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="01b1-5112-ab45-1afc" shared="true" includeChildSelections="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="f079-501a-2738-6844" shared="true" includeChildSelections="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="8e6f-2dd7-a7ed-489e" shared="true" includeChildSelections="true"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
          <costs>
            <cost name="pts" typeId="points" value="40"/>
            <cost name="Destiny Points" typeId="bc33-05f5-8d3f-af43" value="0"/>
            <cost name="Force Category - PTG" typeId="e63c-79ff-93ba-c5eb" value="0"/>
            <cost name="Force Category - GHB" typeId="de92-2099-fbf7-a156" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Fearless Exemplars" hidden="true" id="f461-6e4c-945a-d252" publicationId="f894-7929-f79a-a269">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="11d0-98fb-a420-e622"/>
          </constraints>
          <profiles>
            <profile name="Front-Line Leader" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="4d8e-c223-eecd-eaca">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Hero Phase</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a friendly **^^Cities of Sigmar Human Infantry Hero^^** to use this ability. Then, you can pick up to 1 friendly non-**^^Hero Human Infantry^^** unit and up to 1 friendly **^^Human War Machine^^** unit that are wholly within 12&quot; of that **^^Hero^^** to be the targets.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">While the targets are wholly within 12&quot; of that **^^Hero^^**, add 1 to the Rend characteristic of the target **^^Infantry^^** unit's melee weapons and the target **^^War Machine^^** unit's ranged weapons until the start of your next turn.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="78a1-f6c2-71b8-270a" shared="true"/>
                    <condition type="instanceOf" value="1" field="selections" scope="ancestor" childId="f079-501a-2738-6845" shared="true"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Thrall Warhost" hidden="false" id="a84c-75af-aa84-54d4" publicationId="7454-bbda-d2b6-0747">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d894-d5ab-e2c3-3f2e"/>
          </constraints>
          <profiles>
            <profile name="Have No Mercy" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="c28c-0093-550a-d7d0">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Start of Battle Round</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible enemy unit to be the target.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of the next battle round, add 1 to wound rolls for combat attacks made by friendly **^^Cities of Sigmar Aelf^^** units that target that enemy unit while it is damaged or has had any models slain in the same turn.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Black</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Grudgebound War Throng" hidden="false" id="6c05-ce03-fc9a-5f87" publicationId="7454-bbda-d2b6-0747">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ae80-9134-6c1b-be87"/>
          </constraints>
          <profiles>
            <profile name="I&apos;ve Seen Worse and Killed Batter" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="f1d5-c4b2-abe2-7a7c">
              <characteristics>
                <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Enemy Combat Phase</characteristic>
                <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick an enemy unit that charged this turn and is in combat with any friendly **^^Cities of Sigmar Duardin^^** units that did not charge this turn to be the target.</characteristic>
                <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice. On a 4+, other than the **Companion** weapon ability, weapon abilities for the target's combat attacks have no effect for the rest of the turn.</characteristic>
                <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
              </characteristics>
              <attributes>
                <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                <attribute name="Type" typeId="6d16-c86b-2698-85a4">Defensive</attribute>
                <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
              </attributes>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <constraints>
