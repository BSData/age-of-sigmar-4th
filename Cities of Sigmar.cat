  <sharedSelectionEntryGroups>
    <selectionEntryGroup name="Artefacts of Power" id="d6f1-33e2-673e-c0c8" hidden="false">
      <selectionEntryGroups>
        <selectionEntryGroup name="Treasures of the Cities" id="1c5a-e23a-c603-5edc" hidden="false">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="The Last Blade of Embergard" hidden="false" id="58c1-61c4-2be2-cf30">
              <profiles>
                <profile name="The Last Blade of Embergard" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="96b7-38d0-c137-856">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Deployment Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">This unit can use this ability while it is in reserve. Pick 1 of this unit&apos;s non-**Companion** melee weapons. Add 2 to that weapon&apos;s Attacks characteristic and Rend characteristic for the rest of the battle.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Black</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="7c66-6d5f-823-57f4" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Bones of Saint Ignifus" hidden="false" id="98dc-9f8e-95e1-fc8e">
              <profiles>
                <profile name="Bones of Saint Ignifus" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="ff-fea1-9cae-7fdf">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: You declared a **^^Spell^^** or **^^Prayer^^** ability for a visible unit that is wholly within 12&quot; of this unit and **under orders**</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Add 1 to the casting roll or chanting roll for that ability.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Special</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="a79e-82e8-960-8755" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="The Sphere Celestial" hidden="false" id="c244-fb99-a193-4a8d">
              <profiles>
                <profile name="The Sphere Celestial" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="d4cf-cc63-c61c-4f4d">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Your Hero Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">If this unit is not in combat, pick a point on the battlefield within 1&quot; of this unit and more than 3&quot; from all other units (friendly and enemy) and terrain features to be the target point. Then, pick another visible friendly **^^Cities of Sigmar Infantry^^** or ^^**Cavalry Hero^^** that is wholly within 18&quot; of this unit and not in combat to be the target unit.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Remove this unit from the battlefield and set it up again within 1&quot; of the target unit and not in combat. Then, remove the target from the battlefield and set it up again within 1&quot; of the target point and not in combat. This unit and the target unit can use **^^Move^^** abilities in the following movement phase (this is an exception to Core Rules, 24.0).</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="6ca7-a3fe-87fb-8fcb" includeChildSelections="true"/>
              </constraints>
              <costs>
                <cost name="Destiny Points" typeId="bc33-05f5-8d3f-af43" value="0"/>
                <cost name="Force Category - PTG" typeId="e63c-79ff-93ba-c5eb" value="0"/>
                <cost name="Force Category - GHB" typeId="de92-2099-fbf7-a156" value="0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="7a7a-c75f-42ff-f6ce" hidden="true">
              <description>**^^Hero^^** only, excluding **Cannonade Cogfort** and **Conqueror Cogfort**</description>
            </rule>
          </rules>
          <modifiers>
            <modifier type="set" value="true" field="hidden">
              <conditionGroups>
                <conditionGroup type="or">
                  <conditions>
                    <condition type="instanceOf" value="1" field="selections" scope="root-entry" childId="0d8d-7bb3-c366-acd2" shared="true" childName="Cannonade Cogfort"/>
                    <condition type="instanceOf" value="1" field="selections" scope="root-entry" childId="452b-b02c-4096-b008" shared="true" childName="Conqueror Cogfort"/>
                  </conditions>
                </conditionGroup>
              </conditionGroups>
            </modifier>
          </modifiers>
        </selectionEntryGroup>
      </selectionEntryGroups>
      <entryLinks>
        <entryLink import="true" name="Artefacts of Power" hidden="false" id="0c08-2343-179b-4434" type="selectionEntryGroup" targetId="e1b2-cedf-56a5-6bb1" flatten="true"/>
        <entryLink import="true" name="Artefacts of Power" hidden="false" id="a827-fe34-0202-8468" type="selectionEntryGroup" targetId="d563-838a-a901-097e"/>
      </entryLinks>
      <modifiers>
        <modifier type="set" value="-1" field="d7df-ecaf-ca86-146a">
          <conditions>
            <condition type="atLeast" value="1" field="e63c-79ff-93ba-c5eb" scope="roster" childId="any" shared="true" includeChildSelections="true" includeChildForces="true"/>
          </conditions>
        </modifier>
      </modifiers>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="d7df-ecaf-ca86-146a" includeChildSelections="true"/>
