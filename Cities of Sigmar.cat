        <selectionEntryGroup name="Sentinels of Order" id="be90-b077-70e3-47e0" hidden="false" publicationId="a746-732d-1a22-460">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Stentorian General" hidden="false" id="5469-10c8-8b60-dfc6">
              <profiles>
                <profile name="Stentorian General" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="4959-5ede-1b79-3ce1">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Subtract 1 from ward rolls for enemy units while they are in combat with any visible friendly units that are wholly within 12&quot; of this unit and **under orders**.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Red</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Offensive</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="b51-4a25-1406-a03d" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Beloved Leader" hidden="false" id="75b5-4219-e6f3-e89b">
              <profiles>
                <profile name="Beloved Leader" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="50bc-2de2-fd14-7f25">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Ignore negative modifiers to hit rolls and wound rolls applied by enemy abilities for attacks made by visible friendly units that are wholly within 12&quot; of this unit and **under orders**.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Green</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
