        <profile name="Ever Growing" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="8c86-1655-c6c7-be0b">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle Round, Start of Battle Round</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick the closest terrain feature to this terrain feature that does not have a friendly **overgrown token** to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If the target is not controlled by your opponent, give that target a friendly **overgrown token**.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
