        <profile name="Gossamid Commander" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="6dfc-e0b8-16a-f3bb">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">If this unit charged this turn, pick a visible friendly **Gossamid Archers** unit that is not in combat and is wholly within 18&quot; of this unit to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">The target can immediately use a **^^Shoot^^** ability as if it were your shooting phase but all of the attacks made as part of that **^^Shoot^^** ability must target an enemy unit that is in combat with this unit.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
