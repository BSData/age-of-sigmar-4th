                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army). End of Any Turn</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If this unit used a **^^Fight^^** ability this turn and is wholly within the **creeping overgrowth**, remove it from the battlefield and set it up again on the battlefield more than 9&quot; from all enemy units and wholly within the **creeping overgrowth**.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                      </characteristics>
                      <attributes>
