          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Movement Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible terrain feature that has a friendly **overgrown token** and is within 12&quot; of this unit. Then, pick a friendly non-**^^Unique Kurnothi^^** or **^^Treelord^^** unit that has been destroyed to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Set up a replacement unit with 1 model from the target unit wholly within 6&quot; of that terrain feature and more than 9&quot; from all enemy units. Then, remove the friendly **overgrown token** from that terrain feature. If the target was a **Treelord**, allocate 10 damage points to the replacement unit (ward rolls cannot be made for those damage points).</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
