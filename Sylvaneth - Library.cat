                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Your Hero Phase</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible friendly **^^Sylvaneth^^** unit wholly within 12&quot; of this unit to be the target.</characteristic>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Pick 1 of the following effects:
• **Heal (D3)** the target.
