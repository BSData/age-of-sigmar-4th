        <profile name="Alarielle the Everqueen" typeId="ff03-376e-972f-8ab2" typeName="Unit" hidden="false" id="d715-b233-4833-22e7">
          <characteristics>
            <characteristic name="Move" typeId="fed0-d1b3-1bb8-c501">14&quot;</characteristic>
