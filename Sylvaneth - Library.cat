        <profile name="Kelthannor, the Forest Prince" typeId="ff03-376e-972f-8ab2" typeName="Unit" hidden="false" id="a87b-8479-73fc-cbb0">
          <characteristics>
            <characteristic name="Move" typeId="fed0-d1b3-1bb8-c501">12&quot;</characteristic>
