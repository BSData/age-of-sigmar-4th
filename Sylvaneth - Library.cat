                    <profile name="Spirit-step" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="3e43-7418-5997-48c2">
                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Movement Phase</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If this unit is in combat, it can make a pile-in move. Then, you can pick an enemy unit in combat with this unit and roll a D3. On a 2+, inflict an amount of mortal damage on the enemy unit equal to the roll.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
