              <profiles>
                <profile name="Hero of the Killing Games" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="577e-8687-8656-9716">
                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">For the rest of the turn, while this unit is in combat with any enemy **^^Heroes^^**:
• Add 1 to the Attacks, Rend, and Damage characteristics of this unit&apos;s melee weapons.
• All of its combat attacks must target the same enemy **^^Hero^^**.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Red</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Offensive</attribute>
