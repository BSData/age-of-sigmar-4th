                  <characteristics>
                    <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
                    <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While a friendly **^^Twin^^** is within 3&quot; of and visible to this unit, subtract 1 from hit rolls for attacks that target that **^^Twin^^** and this unit.
While 2 friendly **^^Twins^^** are within 3&quot; of and visible to this unit, subtract 1 from hit rolls and wound rolls for attacks that target those **^^Twins^^** and this unit instead.</characteristic>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Green</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
