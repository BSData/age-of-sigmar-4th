            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Open the Gates!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="a0f1-03ef-6a56-5862">
          <characteristics>
