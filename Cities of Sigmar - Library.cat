                <selectionEntry type="upgrade" import="true" name="Impatient Onrusher" hidden="false" id="9d53-3b2e-6756-f499">
                  <profiles>
                    <profile name="Impatient Onrusher" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="3537-47c5-0af1-a68f">
                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Deployment Phase</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick up to 2 other visible friendly **^^Sigmarite^^** units wholly within 12&quot; of this unit to be the targets.</characteristic>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">This unit and the targets can each use the &apos;Normal Move&apos; ability as if it were your movement phase. This unit must move before any targets, and it must end that move more than 12&quot; from all enemy units and not within enemy territory. Each target must end their move within this unit&apos;s combat range.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                      </characteristics>
