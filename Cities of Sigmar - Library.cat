          </attributes>
        </profile>
        <profile name="Right Tools for the Job" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="913d-a159-a223-9eb9">
          <characteristics>
            <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
            <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Double the Damage characteristic of this unit&apos;s melee weapons for attacks that target the enemy **mark**.</characteristic>
          </characteristics>
          <attributes>
