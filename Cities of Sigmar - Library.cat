        <profile name="Bolt from the Blue" typeId="5946-234-d7b4-6195" typeName="Ability (Prayer)" hidden="false" id="e4fe-770f-7c25-5bc8">
          <characteristics>
            <characteristic name="Timing" typeId="76bf-8126-64d4-c709">Your Hero Phase</characteristic>
            <characteristic name="Chanting Value" typeId="f192-6780-8138-9cef">5</characteristic>
            <characteristic name="Declare" typeId="284c-90b2-245b-adf3">You can pick a visible enemy unit within 12&quot; of this unit to be the target. Then, make a chanting roll of D6.</characteristic>
            <characteristic name="Effect" typeId="6219-6fcc-5ae2-a6b7">This unit has **^^Ward (5+) for the rest of the turn. If a target was picked, inflict D3 mortal damage on the target. If the chanting roll was 10+, inflict 3 mortal damage on the target instead.</characteristic>
            <characteristic name="Keywords" typeId="e3d8-f58b-e4e0-8e9d">**^^Prayer^^**</characteristic>
          </characteristics>
          <attributes>
