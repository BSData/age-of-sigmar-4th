          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Enemy Hero Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">If this unit is not in combat, pick a visible friendly **^^Sigmarite Infantry^^** unit wholly within 18&quot; of it and that is not in combat to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">The target can immediately use the &apos;Normal Move&apos; ability as if it were your movement phase. In addition, the target is **under orders** for the rest of the battle round.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
