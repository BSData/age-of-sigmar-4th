                      <characteristics>
                        <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Start of Third Battle Round</characteristic>
                        <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                        <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the battle, while they are wholly within 6&quot; of this unit, other visible friendly non-**^^Hero Sigmarite^^** units have **^^Strike-first^^**.</characteristic>
                        <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                        <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                      </characteristics>
