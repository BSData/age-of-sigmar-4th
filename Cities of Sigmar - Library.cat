            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Dawner&apos;s Triumph" typeId="ff03-376e-972f-8ab2" typeName="Unit" hidden="false" id="344e-2884-969e-2fc7">
          <characteristics>
