        <categoryLink name="HERO" hidden="false" id="f3d5-20e2-0d78-d758" targetId="6e72-1656-d554-528a" primary="true"/>
        <categoryLink name="ORDER" hidden="false" id="2ded-35a2-b8ef-6d90" targetId="ee22-3575-6590-25c" primary="false"/>
