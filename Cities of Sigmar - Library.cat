        </profile>
        <profile name="Paralysing Venom" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="d0cd-c950-586e-dd44">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick an enemy unit in combat with this unit to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice. If the roll is equal to or less than the target&apos;s Health characteristic, subtract 1 from wound rolls for the target&apos;s attacks for the rest of the turn.</characteristic>
