        <profile name="Hexbane&apos;s Hunters" typeId="ff03-376e-972f-8ab2" typeName="Unit" hidden="false" id="5fba-9c0e-1318-cb18">
          <characteristics>
            <characteristic name="Move" typeId="fed0-d1b3-1bb8-c501">5&quot;</characteristic>
