        <profile name="Piercing Bloodroar" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="fa49-a1dc-a44e-95c4">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick up to 3 enemy units in combat with this unit to be the targets.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice for each target. On a 4+, the target cannot use commands for the rest of the turn.</characteristic>
