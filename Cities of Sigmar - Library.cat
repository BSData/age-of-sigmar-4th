        <profile name="Fury of the Faithful" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="2eca-8671-d0bf-9d12">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible enemy unit within 6&quot; of this terrain feature to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If this terrain feature is in combat, apply the effect below. Otherwise, roll a dice. On a 3+, apply the effect below.
For the rest of the turn, melee weapons used by friendly **^^Cities of Sigmar Infantry^^** and **^^Cavalry^^** units have **Crit (Auto-wound)** for attacks that target that enemy unit.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
