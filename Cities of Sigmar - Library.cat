            <characteristic name="Control" typeId="6c6f-8510-9ce1-fc6e">2</characteristic>
          </characteristics>
        </profile>
        <profile name="Harrying Attacks" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="0758-9662-bc46-755e">
          <characteristics>
            <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
            <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">While this unit&apos;s **Thexa** is next to an enemy unit, that enemy unit&apos;s attacks cannot score critical hits (treat them as regular hits instead).</characteristic>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Green</attribute>
            <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Defensive</attribute>
            <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
          </attributes>
        </profile>
        <profile name="Prowling Ash Panther" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="ebde-a75b-562f-c7fb">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Any Combat Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">This unit&apos;s **Thexa** is a token. If this unit&apos;s **Thexa** is not on the battlefield, pick an enemy unit in combat with this unit to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Place this unit&apos;s **Thexa** next to the target, then roll a D3. On a 2+, inflict an amount of mortal damage on the target equal to the roll. If the target is destroyed while this unit&apos;s **Thexa** is next to it, remove this unit&apos;s **Thexa** from the battlefield.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Fluid Combat Style" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="109d-d64b-fe8b-49e0">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: You declared a **^^Fight^^** ability for this unit or a non-**^^Hero Sigmarite Infantry^^** unit wholly within 12&quot; of this unit.</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Immediately after the **^^Fight^^** ability used by that unit has been resolved, pick a point on the battlefield within 6&quot; of this unit and more than 3&quot; from all units (friendly and enemy) and terrain features. Remove the unit that used the **^^Fight^^** ability from the battlefield and set it up again wholly within 6&quot; of that point and not in combat.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="d136-9f76-c527-4ad0" includeChildSelections="true"/>
      </constraints>
