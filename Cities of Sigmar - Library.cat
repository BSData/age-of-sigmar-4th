        <profile name="Full Charge!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="4e71-1c15-438d-85b4">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Any Hero Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Pick 1 or more of the following effects. For each effect you pick, give this unit a number of **heat tokens** equal to the number beside it.
**1 *Breaching Assist!*:** If this unit uses the &apos;Sally Forth&apos; ability this turn, melee weapons used by the targets of that ability have **Charge (+1 Damage)** for the rest of the turn.
**2 *Full Throttle*:** For the rest of the turn, this unit&apos;s Move characteristic is 10&quot;.
**3 *Repel Boarders!*:** For the rest of the turn, add 2 to the Attacks characteristic of this unit&apos;s **Leadshotters** and **Crushing Iron Feet**.
**4 *Disengage Safeties!*:** For the rest of the turn, the Attacks characteristic of this unit&apos;s **Realmscorcher Flame Cannon** is 22.
**6 *Get Us Out of Here!*:** For the rest of the turn, this unit can use **^^Shoot^^** abilities even if it used a **^^Retreat^^** ability in the same turn.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Yellow</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Special</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Overheating" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="9d85-fad5-328f-0e82">
          <characteristics>
            <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
            <characteristic name="Effect" typeId="fd7f-888d-3257-a12b">Immediately after resolving this unit&apos;s &apos;Full Power!&apos; ability, you must roll a number of dice equal to the number of **heat tokens** this unit has. For each 5+, allocate 1 damage point to this unit (ward rolls cannot be made for those damage points), then remove 1 of this unit&apos;s **heat tokens**.</characteristic>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
            <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Special</attribute>
            <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
          </attributes>
        </profile>
        <profile name="All Aboard!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="a24a-0a0a-4abf-6c6b">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Deployment Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick up to 1 friendly **^^Sigmarite Infantry Hero^^** and up to 1 friendly non-**^^Hero Sigmarite Infantry^^** unit that have not been deployed.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Set up those units in reserve as this unit&apos;s **passengers**. They have now been deployed.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f">**^^Deploy^^**</characteristic>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Black</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Special</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
        <profile name="Sally Forth" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="7e00-4344-45b2-25cf">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Any Charge Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">If this unit has not used a **^^Run^^** ability this turn, pick this unit&apos;s **passengers** to be the targets.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Set up each target wholly within 6&quot; of this unit and either not in combat or within 1/2&quot; of an enemy unit. If a target is set up in combat, it has charged. Then, if this unit is not **under orders**, this unit and the targets are **under orders** for the rest of the battle round.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
          <attributes>
            <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Orange</attribute>
            <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
            <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
          </attributes>
        </profile>
      </profiles>
