        <profile name="Portents of Battle" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="3e84-9072-f8af-e91d">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Your Hero Phase</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible friendly **^^Cities of Sigmar Human^^** unit wholly within 12&quot; of this unit to be the target.</characteristic>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Roll a dice. On a 3+, add 1 to hit rolls for the target&apos;s combat attacks until the start of your next turn.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
