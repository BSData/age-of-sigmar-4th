      <profiles>
        <profile name="Hauled to War" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="9233-1d25-f3ba-22b7">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Turn (Army), Reaction: You declared the &apos;Normal Move&apos; ability for a **^^Cities of Sigmar Infantry^^** unit within 3&quot; of this terrain feature</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">After the &apos;Normal Move&apos; ability has been resolved, pick a point on the battlefield within 1&quot; of the unit that used that ability and within 6&quot; of this terrain feature. Remove this terrain feature from the battlefield and set it up again within 1&quot; of that point and more than 3&quot; from all enemy units.</characteristic>
            <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
            <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
          </characteristics>
