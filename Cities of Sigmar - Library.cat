        <profile name="Tactical Acumen" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="2402-bae6-698b-bd1">
          <characteristics>
            <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Reaction: You declared the &apos;Redeploy&apos; command for a friendly **^^Cities of Sigmar Human^^** unit wholly within 12&quot; of this unit</characteristic>
            <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
            <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If you roll a 1-3 when determining the distance that unit can move, you can use a value of 4 instead.</characteristic>
