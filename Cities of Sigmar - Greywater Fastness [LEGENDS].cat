          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Seat on the Council" hidden="false" id="235b-ba0b-79b3-54da">
              <profiles>
                <profile name="Seat on the Council" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="e9a6-b264-3a97-b908">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Your Hero Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a visible friendly **^^Greywater Fastness^^** unit that is wholly within 12&quot; of this unit, that is under orders and that has a **Firing Drill** to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">The target can use its **Firing Drill** ability this turn even if it has already used it this battle.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Yellow</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Special</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
