    <selectionEntryGroup name="Firing Drills" id="3ab0-b0f6-a64d-6d1e" hidden="false">
      <selectionEntryGroups>
        <selectionEntryGroup name="Firing Drills: Greywater Fastness" id="3d5e-1a3a-cf1e-a067" hidden="false" publicationId="dadd-06f0-3f38-c6f3">
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Close-range Salvo!" hidden="false" id="862d-e724-7d16-7a8e">
              <profiles>
                <profile name="Close-range Salvo!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="ef34-0a0e-6ef8-ec5e">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Your Shooting Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">If this unit is **under orders**, for the rest of the phase, this unit&apos;s ranged weapons have **Shoot in Combat**.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="50fe-4f29-6bc3-dcc6">Blue</attribute>
                    <attribute name="Type" typeId="bf11-4e10-3ab1-06f4">Shooting</attribute>
                    <attribute name="Parent Node" typeId="e2e1-15ca-d345-22b8"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="038a-a92b-0a37-4ba7" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Deafen Them with Fire!" hidden="false" id="3275-1756-4e6c-c0d6">
              <profiles>
                <profile name="Deafen Them with Fire!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="53fa-4835-0a4f-0717">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Your Shooting Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">If this unit is **under orders**, pick a **pinned** enemy unit that was the target of all this unit&apos;s shooting attacks this turn to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of your next turn, each time your opponent declares a command for the target, unless they spend 1 additional command point to use that command, the command has no effect, it still counts as having been used and the command points spent to use the command are still lost.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Shooting</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="bf41-62dd-5b33-7770" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Hold Them Back!" hidden="false" id="b71c-5513-0851-0776">
              <profiles>
                <profile name="Hold Them Back!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="ec45-0693-a75f-472e">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Your Shooting Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb">Pick a **pinned** enemy unit to be the target.</characteristic>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of your next turn, your opponent must subtract 1 from the number of dice rolled when making charge rolls for the target, to a minimum of 1.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Movement</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="c3e5-9ab3-086f-9771" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Repel the Enemy!" hidden="false" id="92ce-7441-1f6c-ace9">
              <profiles>
                <profile name="Repel the Enemy!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="cfce-e8bc-f335-9977">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Any Combat Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">For the rest of the turn, add 1 to wound rolls for combat attacks made by this unit that target a **pinned** enemy unit.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Red</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Offensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="7c25-89fd-5ea7-f73c" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Hunker Down!" hidden="false" id="4613-6302-8f29-165f">
              <profiles>
                <profile name="Hunker Down!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="8b5c-a1f7-2164-84c4">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per Battle, Enemy Movement Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of your next turn:
• Subtract 1 from the Rend characteristic of weapons used for attacks made by m**pinned** enemy units that target this unit.
• This unit cannot use **^^Charge^^** abilities unless it is **under orders**.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Grey</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="5bfe-7980-5777-6dc0" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="Load Smokeshots!" hidden="false" id="e1f5-4228-4d01-dc25">
              <profiles>
                <profile name="Load Smokeshots!" typeId="59b6-d47a-a68a-5dcc" typeName="Ability (Activated)" hidden="false" id="930b-859b-f227-ff9a">
                  <characteristics>
                    <characteristic name="Timing" typeId="652c-3d84-4e7-14f4">Once Per  Battle, Your Shooting Phase</characteristic>
                    <characteristic name="Declare" typeId="bad3-f9c5-ba46-18cb"/>
                    <characteristic name="Effect" typeId="b6f1-ba36-6cd-3b03">Until the start of your next turn, this unit is not visible to enemy units while they are more than 3&quot; away from it.</characteristic>
                    <characteristic name="Keywords" typeId="12e8-3214-7d8f-1d0f"/>
                    <characteristic name="Used By" typeId="1b32-c9d6-3106-166b"/>
                  </characteristics>
                  <attributes>
                    <attribute name="Color" typeId="5a11-eab3-180c-ddf5">Blue</attribute>
                    <attribute name="Type" typeId="6d16-c86b-2698-85a4">Defensive</attribute>
                    <attribute name="Parent Node" typeId="2d74-4dcd-8468-87fa"/>
                  </attributes>
                </profile>
              </profiles>
              <constraints>
                <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="24d9-90c0-353a-b321" includeChildSelections="true"/>
              </constraints>
            </selectionEntry>
          </selectionEntries>
          <rules>
            <rule name="Enhancement Restrictions" id="0ae8-14ff-955a-ac5d" hidden="true">
              <description>A Firing Drill is a unique enhancement that can be given to non-**^^Hero Greywater Fastness^^** units. A unit can only have 1 **Firing Drill**.</description>
            </rule>
          </rules>
        </selectionEntryGroup>
      </selectionEntryGroups>
