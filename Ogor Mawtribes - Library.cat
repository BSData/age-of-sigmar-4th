        <profile name="Biggest-Game Hunter" typeId="907f-a48-6a04-f788" typeName="Ability (Passive)" hidden="false" id="d37a-109c-5d74-6f43">
          <characteristics>
            <characteristic name="Keywords" typeId="b977-7c5e-33b2-428e"/>
